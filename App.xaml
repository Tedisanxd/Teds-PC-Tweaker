<Application x:Class="TedsPCTweaker.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="MainWindow.xaml">
  <Application.Resources>
    <SolidColorBrush x:Key="BgBrush"       Color="#0D0D0D"/>
    <SolidColorBrush x:Key="SurfaceBrush"  Color="#141414"/>
    <SolidColorBrush x:Key="CardBrush"     Color="#1E1E1E"/>
    <SolidColorBrush x:Key="BorderBrush"   Color="#2E2E2E"/>
    <SolidColorBrush x:Key="AccentBrush"   Color="#00C8FF"/>
    <SolidColorBrush x:Key="AccentDimBrush" Color="#004A5E"/>
    <SolidColorBrush x:Key="TextBrush"     Color="#F0F0F0"/>
    <SolidColorBrush x:Key="TextDimBrush"  Color="#888888"/>
    <SolidColorBrush x:Key="SuccessBrush"  Color="#00E676"/>
    <SolidColorBrush x:Key="WarnBrush"     Color="#FFB300"/>
    <SolidColorBrush x:Key="DangerBrush"   Color="#FF5252"/>
    <SolidColorBrush x:Key="NavActiveBrush" Color="#1A3340"/>
  </Application.Resources>
</Application>
