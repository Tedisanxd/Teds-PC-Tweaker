<Window x:Class="TedsPCTweaker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:TedsPCTweaker"
        Title="Ted's PC Tweaker" Height="740" Width="1100"
        MinHeight="620" MinWidth="920"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI Variable Text, Segoe UI"
        Background="#0B0B0D"
        Foreground="#E4E4E8">

  <Window.Resources>

    <local:CategoryIconConverter x:Key="CatIcon"/>

    <!-- ── Animated Toggle Switch ────────────────────────────────────── -->
    <Style x:Key="ToggleSwitch" TargetType="CheckBox">
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="CheckBox">
            <Grid Width="50" Height="28" VerticalAlignment="Center">

              <VisualStateManager.VisualStateGroups>
                <VisualStateGroup x:Name="CheckStates">
                  <VisualStateGroup.Transitions>
                    <VisualTransition From="Unchecked" To="Checked" GeneratedDuration="0:0:0">
                      <Storyboard>
                        <DoubleAnimation Storyboard.TargetName="ThumbTx"
                                         Storyboard.TargetProperty="X"
                                         To="22" Duration="0:0:0.22">
                          <DoubleAnimation.EasingFunction>
                            <BackEase EasingMode="EaseOut" Amplitude="0.3"/>
                          </DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                        <ColorAnimation Storyboard.TargetName="TrackBrush"
                                        Storyboard.TargetProperty="Color"
                                        To="#00AADD" Duration="0:0:0.18"/>
                        <ColorAnimation Storyboard.TargetName="ThumbBrush"
                                        Storyboard.TargetProperty="Color"
                                        To="#FFFFFF" Duration="0:0:0.13"/>
                      </Storyboard>
                    </VisualTransition>
                    <VisualTransition From="Checked" To="Unchecked" GeneratedDuration="0:0:0">
                      <Storyboard>
                        <DoubleAnimation Storyboard.TargetName="ThumbTx"
                                         Storyboard.TargetProperty="X"
                                         To="0" Duration="0:0:0.18">
                          <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                          </DoubleAnimation.EasingFunction>
                        </DoubleAnimation>
                        <ColorAnimation Storyboard.TargetName="TrackBrush"
                                        Storyboard.TargetProperty="Color"
                                        To="#222228" Duration="0:0:0.18"/>
                        <ColorAnimation Storyboard.TargetName="ThumbBrush"
                                        Storyboard.TargetProperty="Color"
                                        To="#484855" Duration="0:0:0.13"/>
                      </Storyboard>
                    </VisualTransition>
                  </VisualStateGroup.Transitions>

                  <VisualState x:Name="Unchecked"/>
                  <VisualState x:Name="Checked">
                    <Storyboard>
                      <DoubleAnimation Storyboard.TargetName="ThumbTx"
                                       Storyboard.TargetProperty="X" To="22" Duration="0:0:0"/>
                      <ColorAnimation Storyboard.TargetName="TrackBrush"
                                      Storyboard.TargetProperty="Color" To="#00AADD" Duration="0:0:0"/>
                      <ColorAnimation Storyboard.TargetName="ThumbBrush"
                                      Storyboard.TargetProperty="Color" To="#FFFFFF" Duration="0:0:0"/>
                    </Storyboard>
                  </VisualState>
                  <VisualState x:Name="Indeterminate"/>
                </VisualStateGroup>

                <VisualStateGroup x:Name="CommonStates">
                  <VisualState x:Name="Normal"/>
                  <VisualState x:Name="MouseOver"/>
                  <VisualState x:Name="Disabled">
                    <Storyboard>
                      <DoubleAnimation Storyboard.TargetName="Root"
                                       Storyboard.TargetProperty="Opacity" To="0.28" Duration="0:0:0"/>
                    </Storyboard>
                  </VisualState>
                </VisualStateGroup>
              </VisualStateManager.VisualStateGroups>

              <Grid x:Name="Root">
                <Border x:Name="Track" CornerRadius="14">
                  <Border.Background>
                    <SolidColorBrush x:Name="TrackBrush" Color="#222228"/>
                  </Border.Background>
                </Border>
                <Ellipse x:Name="Thumb" Width="22" Height="22"
                         HorizontalAlignment="Left" VerticalAlignment="Center" Margin="3,0,0,0">
                  <Ellipse.Fill>
                    <SolidColorBrush x:Name="ThumbBrush" Color="#484855"/>
                  </Ellipse.Fill>
                  <Ellipse.RenderTransform>
                    <TranslateTransform x:Name="ThumbTx" X="0"/>
                  </Ellipse.RenderTransform>
                </Ellipse>
              </Grid>
            </Grid>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- ── Sidebar nav button ────────────────────────────────────────── -->
    <Style x:Key="NavBtn" TargetType="RadioButton">
      <Setter Property="GroupName" Value="Nav"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
      <Setter Property="Height" Value="48"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="RadioButton">
            <Grid Margin="10,2">

              <VisualStateManager.VisualStateGroups>
                <VisualStateGroup x:Name="CommonStates">
                  <VisualStateGroup.Transitions>
                    <VisualTransition GeneratedDuration="0:0:0.15">
                      <VisualTransition.GeneratedEasingFunction>
                        <CubicEase EasingMode="EaseOut"/>
                      </VisualTransition.GeneratedEasingFunction>
                    </VisualTransition>
                  </VisualStateGroup.Transitions>
                  <VisualState x:Name="Normal"/>
                  <VisualState x:Name="MouseOver">
                    <Storyboard>
                      <ColorAnimation Storyboard.TargetName="HoverBrush"
                                      Storyboard.TargetProperty="Color"
                                      To="#16161E" Duration="0:0:0"/>
                    </Storyboard>
                  </VisualState>
                  <VisualState x:Name="Pressed"/>
                  <VisualState x:Name="Disabled"/>
                </VisualStateGroup>
              </VisualStateManager.VisualStateGroups>

              <!-- Hover fill -->
              <Border CornerRadius="8">
                <Border.Background>
                  <SolidColorBrush x:Name="HoverBrush" Color="Transparent"/>
                </Border.Background>
              </Border>

              <!-- Active fill — on top of hover -->
              <Border x:Name="ActiveBg" CornerRadius="8" Background="#0C1E30" Opacity="0"/>

              <!-- Left accent strip -->
              <Rectangle x:Name="Strip" Width="3" HorizontalAlignment="Left"
                         RadiusX="1.5" RadiusY="1.5" Margin="0,12,0,12"
                         Fill="#00C8FF" Opacity="0"/>

              <!-- Icon + label -->
              <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,12,0">
                <TextBlock x:Name="Icon"
                           Text="{Binding Tag, RelativeSource={RelativeSource TemplatedParent},
                                  Converter={StaticResource CatIcon}}"
                           FontFamily="Segoe MDL2 Assets" FontSize="14"
                           Foreground="#363645" VerticalAlignment="Center" Margin="0,0,11,0"/>
                <TextBlock x:Name="Label"
                           Text="{TemplateBinding Content}"
                           FontSize="13" Foreground="#4E4E60" VerticalAlignment="Center"/>
              </StackPanel>

            </Grid>
            <ControlTemplate.Triggers>
              <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="ActiveBg" Property="Opacity"    Value="1"/>
                <Setter TargetName="Strip"    Property="Opacity"    Value="1"/>
                <Setter TargetName="Label"    Property="Foreground" Value="#00C8FF"/>
                <Setter TargetName="Icon"     Property="Foreground" Value="#0099CC"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- ── Primary button ────────────────────────────────────────────── -->
    <Style x:Key="PrimaryBtn" TargetType="Button">
      <Setter Property="Background"      Value="#0A6A8F"/>
      <Setter Property="Foreground"      Value="#E8F8FF"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding"         Value="20,9"/>
      <Setter Property="FontSize"        Value="12"/>
      <Setter Property="FontWeight"      Value="Medium"/>
      <Setter Property="Cursor"          Value="Hand"/>
      <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="Bg" CornerRadius="7"
                    Background="{TemplateBinding Background}"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bg" Property="Background" Value="#0D84B0"/>
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Bg" Property="Background" Value="#06506E"/>
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="Bg" Property="Background" Value="#161620"/>
                <Setter Property="Foreground" Value="#383848"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="DangerBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
      <Setter Property="Background" Value="#6A1818"/>
      <Setter Property="Foreground" Value="#FFD0D0"/>
    </Style>

    <Style x:Key="GhostBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
      <Setter Property="Background" Value="#16161E"/>
      <Setter Property="Foreground" Value="#6A6A80"/>
    </Style>

    <Style x:Key="CleanRunBtn" TargetType="Button" BasedOn="{StaticResource PrimaryBtn}">
      <Setter Property="Background" Value="#0E2618"/>
      <Setter Property="Foreground" Value="#00CC68"/>
      <Setter Property="Padding"    Value="16,7"/>
      <Setter Property="FontSize"   Value="11"/>
    </Style>

    <!-- ── Progress bar ──────────────────────────────────────────────── -->
    <Style x:Key="SlimBar" TargetType="ProgressBar">
      <Setter Property="Height" Value="3"/>
      <Setter Property="Background" Value="#1C1C28"/>
      <Setter Property="Foreground" Value="#00C8FF"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ProgressBar">
            <Grid x:Name="PART_Track" ClipToBounds="True">
              <Border Background="{TemplateBinding Background}" CornerRadius="2"/>
              <Border x:Name="PART_Indicator" HorizontalAlignment="Left"
                      Background="{TemplateBinding Foreground}" CornerRadius="2"/>
            </Grid>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- ── Slim scrollbar ────────────────────────────────────────────── -->
    <Style TargetType="ScrollBar">
      <Setter Property="Width"      Value="4"/>
      <Setter Property="Background" Value="Transparent"/>
    </Style>

  </Window.Resources>

  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="200"/>
      <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>
    <Grid.RowDefinitions>
      <RowDefinition Height="52"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="32"/>
    </Grid.RowDefinitions>

    <!-- ═══════════════════════════════════════════════════════════════
         Top bar
    ═══════════════════════════════════════════════════════════════════ -->
    <Border Grid.Row="0" Grid.ColumnSpan="2"
            Background="#080810"
            BorderBrush="#18182A" BorderThickness="0,0,0,1">
      <Grid>
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0">
          <Border Width="7" Height="7" CornerRadius="3.5" Background="#00C8FF" Margin="0,0,10,0" Opacity="0.9"/>
          <TextBlock Text="Ted's PC Tweaker"
                     FontFamily="Segoe UI Variable Display, Segoe UI"
                     FontSize="13.5" FontWeight="SemiBold" Foreground="#E8E8F2"/>
          <TextBlock Text="  ·  by tedisanxd" FontSize="12" Foreground="#2C2C40"
                     VerticalAlignment="Center"/>
        </StackPanel>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                    VerticalAlignment="Center" Margin="16,0">
          <Button x:Name="BtnRestorePoint" Content="Restore Point"
                  Style="{StaticResource GhostBtn}" Margin="0,0,8,0" Click="BtnRestorePoint_Click"
                  ToolTip="Create a Windows System Restore Point before applying tweaks"/>
          <Button x:Name="BtnApplyAll" Content="Apply Selected"
                  Style="{StaticResource PrimaryBtn}" Margin="0,0,8,0" Click="BtnApplyAll_Click"/>
          <Button x:Name="BtnRevertAll" Content="Revert All"
                  Style="{StaticResource DangerBtn}" Click="BtnRevertAll_Click"/>
        </StackPanel>
      </Grid>
    </Border>

    <!-- ═══════════════════════════════════════════════════════════════
         Sidebar
    ═══════════════════════════════════════════════════════════════════ -->
    <Border Grid.Row="1" Grid.Column="0"
            Background="#09090E"
            BorderBrush="#141420" BorderThickness="0,0,1,0">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="*"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,14,0,0">
          <RadioButton x:Name="NavPerformance" Content="Performance"
                       Style="{StaticResource NavBtn}" IsChecked="True"
                       Checked="NavButton_Checked" Tag="Performance"/>
          <RadioButton x:Name="NavPrivacy"     Content="Privacy"
                       Style="{StaticResource NavBtn}"
                       Checked="NavButton_Checked" Tag="Privacy"/>
          <RadioButton x:Name="NavGaming"      Content="Gaming"
                       Style="{StaticResource NavBtn}"
                       Checked="NavButton_Checked" Tag="Gaming"/>
          <RadioButton x:Name="NavNetwork"     Content="Network"
                       Style="{StaticResource NavBtn}"
                       Checked="NavButton_Checked" Tag="Network"/>
          <RadioButton x:Name="NavCleanup"     Content="Cleanup"
                       Style="{StaticResource NavBtn}"
                       Checked="NavButton_Checked" Tag="Cleanup"/>

          <!-- Applied stats card -->
          <Border Margin="12,26,12,0" Background="#0E0E18"
                  CornerRadius="10" Padding="14,13"
                  BorderBrush="#1A1A28" BorderThickness="1">
            <StackPanel>
              <TextBlock Text="TWEAKS APPLIED" FontSize="9" FontWeight="Medium"
                         Foreground="#303045" Margin="0,0,0,9"/>
              <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                <TextBlock x:Name="TxtAppliedCount" Text="0"
                           FontFamily="Segoe UI Variable Display, Segoe UI"
                           FontSize="30" FontWeight="Light" Foreground="#00C8FF" LineHeight="30"/>
                <TextBlock x:Name="TxtTotalCount" Text=" / 0"
                           FontSize="13" Foreground="#282838"
                           VerticalAlignment="Bottom" Margin="2,0,0,3"/>
              </StackPanel>
              <ProgressBar x:Name="PbProgress" Style="{StaticResource SlimBar}"
                           Margin="0,11,0,0" Value="0" Maximum="1"/>
            </StackPanel>
          </Border>
        </StackPanel>

        <!-- Risk legend -->
        <StackPanel Grid.Row="1" Margin="18,0,18,16">
          <TextBlock Text="RISK LEVEL" FontSize="9" FontWeight="Medium"
                     Foreground="#222230" Margin="0,0,0,6"/>
          <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
            <Border Width="7" Height="7" CornerRadius="3.5" Background="#1E9452" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBlock Text="Safe"   FontSize="10" Foreground="#323240"/>
          </StackPanel>
          <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
            <Border Width="7" Height="7" CornerRadius="3.5" Background="#1A6080" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBlock Text="Low"    FontSize="10" Foreground="#323240"/>
          </StackPanel>
          <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
            <Border Width="7" Height="7" CornerRadius="3.5" Background="#806000" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBlock Text="Medium" FontSize="10" Foreground="#323240"/>
          </StackPanel>
          <StackPanel Orientation="Horizontal">
            <Border Width="7" Height="7" CornerRadius="3.5" Background="#801818" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBlock Text="High"   FontSize="10" Foreground="#323240"/>
          </StackPanel>
        </StackPanel>
      </Grid>
    </Border>

    <!-- ═══════════════════════════════════════════════════════════════
         Main content area
    ═══════════════════════════════════════════════════════════════════ -->
    <Grid Grid.Row="1" Grid.Column="1" Background="#0B0B0D">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>

      <!-- Section header -->
      <Border Grid.Row="0" Background="#080810"
              BorderBrush="#141420" BorderThickness="0,0,0,1"
              Padding="26,15,20,15">
        <Grid>
          <StackPanel VerticalAlignment="Center">
            <TextBlock x:Name="TxtCategoryTitle" Text="Performance"
                       FontFamily="Segoe UI Variable Display, Segoe UI"
                       FontSize="17" FontWeight="Medium" Foreground="#EBEBF0"/>
            <TextBlock x:Name="TxtCategorySubtitle"
                       Text="Power plans, services, scheduling and system settings."
                       FontSize="11.5" Foreground="#48485C" Margin="0,3,0,0"/>
          </StackPanel>
          <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
            <Button x:Name="BtnSelectAll"   Content="Select All"
                    Style="{StaticResource GhostBtn}" Margin="0,0,8,0" Click="BtnSelectAll_Click"/>
            <Button x:Name="BtnDeselectAll" Content="Deselect All"
                    Style="{StaticResource GhostBtn}" Click="BtnDeselectAll_Click"/>
          </StackPanel>
        </Grid>
      </Border>

      <!-- Animated content panel -->
      <Border x:Name="ContentPanel" Grid.Row="1">
        <Border.RenderTransform>
          <TranslateTransform x:Name="ContentSlide" Y="0"/>
        </Border.RenderTransform>
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Background="#0B0B0D" Padding="0,0,4,0">
          <ItemsControl x:Name="TweakList" Margin="18,16,18,20">
            <ItemsControl.ItemTemplate>
              <DataTemplate>

                <!-- Tweak card -->
                <Border x:Name="Card" CornerRadius="10" Margin="0,0,0,6"
                        BorderThickness="1" BorderBrush="#18182A">
                  <Border.Background>
                    <SolidColorBrush x:Name="CardBg" Color="#111118"/>
                  </Border.Background>
                  <Border.Triggers>
                    <EventTrigger RoutedEvent="MouseEnter">
                      <BeginStoryboard>
                        <Storyboard>
                          <ColorAnimation Storyboard.TargetName="CardBg"
                                          Storyboard.TargetProperty="Color"
                                          To="#18182A" Duration="0:0:0.07"/>
                        </Storyboard>
                      </BeginStoryboard>
                    </EventTrigger>
                    <EventTrigger RoutedEvent="MouseLeave">
                      <BeginStoryboard>
                        <Storyboard>
                          <ColorAnimation Storyboard.TargetName="CardBg"
                                          Storyboard.TargetProperty="Color"
                                          To="#111118" Duration="0:0:0.22"/>
                        </Storyboard>
                      </BeginStoryboard>
                    </EventTrigger>
                  </Border.Triggers>

                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="3"/>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Risk colour strip -->
                    <Rectangle Grid.Column="0" Fill="{Binding RiskColor}"
                               Opacity="0.85" RadiusX="4" RadiusY="4"/>

                    <!-- Text content -->
                    <StackPanel Grid.Column="1" Margin="16,14,12,14" VerticalAlignment="Center">
                      <!-- Title row -->
                      <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                        <TextBlock Text="{Binding Title}"
                                   FontSize="13" FontWeight="Medium"
                                   Foreground="#D8D8E8" VerticalAlignment="Center"/>
                        <!-- REBOOT badge -->
                        <Border Visibility="{Binding RebootBadgeVisible}"
                                CornerRadius="4" Padding="6,2" Margin="10,0,0,0"
                                Background="#1C1400">
                          <TextBlock Text="REBOOT" FontSize="9" FontWeight="SemiBold"
                                     Foreground="#CC9900"/>
                        </Border>
                        <!-- APPLIED badge -->
                        <Border Visibility="{Binding AppliedBadgeVisible}"
                                CornerRadius="4" Padding="6,2" Margin="6,0,0,0"
                                Background="#0C2018">
                          <TextBlock Text="APPLIED" FontSize="9" FontWeight="SemiBold"
                                     Foreground="#00CC60"/>
                        </Border>
                      </StackPanel>
                      <!-- Description -->
                      <TextBlock Text="{Binding Description}"
                                 FontSize="11.5" Foreground="#505068"
                                 TextWrapping="Wrap" LineHeight="18"/>
                    </StackPanel>

                    <!-- Toggle / Run button -->
                    <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="0,0,16,0">
                      <CheckBox Style="{StaticResource ToggleSwitch}"
                                Visibility="{Binding ToggleVisible}"
                                IsChecked="{Binding IsEnabled, Mode=TwoWay}"/>
                      <Button Content="Run" Style="{StaticResource CleanRunBtn}"
                              Visibility="{Binding CleanupVisible}"
                              Tag="{Binding Id}" Click="CleanupRun_Click"/>
                    </StackPanel>
                  </Grid>
                </Border>

              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>
      </Border>
    </Grid>

    <!-- ═══════════════════════════════════════════════════════════════
         Status bar
    ═══════════════════════════════════════════════════════════════════ -->
    <Border Grid.Row="2" Grid.ColumnSpan="2"
            Background="#080810"
            BorderBrush="#14142A" BorderThickness="0,1,0,0">
      <Grid Margin="20,0">
        <TextBlock x:Name="TxtStatus"
                   Text="Ready  —  run as Administrator for full tweak access."
                   FontSize="11" Foreground="#2E2E42" VerticalAlignment="Center"/>
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
          <TextBlock x:Name="TxtRebootNotice"
                     FontSize="11" Foreground="#806600" Margin="0,0,16,0"/>
          <TextBlock Text="developed by tedisanxd"
                     FontSize="10" Foreground="#1E1E2E" VerticalAlignment="Center"/>
        </StackPanel>
      </Grid>
    </Border>

  </Grid>
</Window>
